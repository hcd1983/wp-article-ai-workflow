# WordPress 網站網址（勿加尾端斜線）
SITE=https://example.com

# WordPress 使用者名稱（後台登入帳號）
USER_NAME=your_wp_username

# WordPress 應用程式密碼（後台：使用者 → 設定檔 → 應用程式密碼）
# 對應 curl -u "USER_NAME:應用程式密碼" 的「應用程式密碼」部分
WP_APP_PASSWORD=your_wp_application_password

# Google Gemini API 金鑰（產圖、可選文案輔助）
# 取得方式：Google AI Studio
GEMINI_API_KEY=your_gemini_api_key

# 文章插圖（可選）
# ILLUSTRATION_ENABLED_DEFAULT=true
# ILLUSTRATION_MAX_PER_ARTICLE=3
# ILLUSTRATION_DEFAULT_STYLE=clean diagram, minimal
# ILLUSTRATION_STRICT_MODE=false

# Pexels 圖庫（可選，使用 --image-source pexels 或插圖計畫 source=pexels 時需要）
# https://www.pexels.com/api/
# PEXELS_API_KEY=
# Pexels 圖是否在 figcaption 顯示攝影師／來源連結（預設 true）
# PEXELS_ATTRIBUTION_DEFAULT=true

# 審稿同步目錄（可選）
# 預設：/Users/hcd1983/article-review/wp-article-ai-workflow
# REVIEW_DRAFTS_DIR=/Users/hcd1983/article-review/wp-article-ai-workflow
